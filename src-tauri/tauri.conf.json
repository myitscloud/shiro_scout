{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-config-schema/refs/heads/main/tauri-conf.json",
  "productName": "Shiro Scout",
  "version": "0.1.0",
  "identifier": "com.shiroscout.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Shiro Scout",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "publisher": "ShiroScout Team",
    "copyright": "Copyright © 2026 ShiroScout Team. All rights reserved.",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US",
        "template": null
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://releases.shiroscout.app/{{target}}/{{current_version}}"
      ],
      "pubkey": "PLACEHOLDER_ED25519_PUBKEY",
      "dialog": true
    }
  }
}
