# ==============================================================================
# ShiroScout Agent Sandbox Docker Image  (rev 2 — exec-only architecture)
# ==============================================================================
#
# Purpose:  Isolated runtime for agent tool execution. The Tauri host drives
#           this container exclusively through the Docker exec API (bollard),
#           per ADR-003. There is NO in-container HTTP server and NO exposed
#           ports: with network_mode: none, exec over the daemon socket is the
#           only channel — which is the point.
#
# Security: air-gapped (network_mode: none), read-only rootfs, cap_drop ALL,
#           no-new-privileges, non-root user (agent, uid/gid 1000).
#           LLM calls never happen here; they are host-side.
#
# Base:     debian:bookworm-slim (glibc — required by the toolchain and
#           Playwright; Alpine/musl intentionally avoided).
#
# Line endings: LF. Keep it that way (FILEOPS).
# ==============================================================================

FROM debian:bookworm-slim

LABEL maintainer="ShiroScout Team"
LABEL description="Exec-only agent sandbox for ShiroScout"
LABEL security.air-gapped="true"
LABEL com.shiroscout.sandbox="true"

ARG DEBIAN_FRONTEND=noninteractive

# Non-root sandbox user — must match `user: "1000:1000"` in container.rs
ARG SANDBOX_UID=1000
ARG SANDBOX_GID=1000
ARG SANDBOX_USER=agent

# Pinned tool versions (update deliberately, not implicitly)
ARG NODE_MAJOR=22
ARG PLAYWRIGHT_VERSION=1.61.1

# ==============================================================================
# SECTION 1: System packages
#   Browser libraries are NOT listed here — `playwright install --with-deps`
#   resolves the exact set for the pinned version (Section 4).
# ==============================================================================

RUN apt-get update && apt-get install -y --no-install-recommends \
    # --- Base utilities ---
    ca-certificates \
    curl \
    wget \
    git \
    jq \
    unzip \
    xz-utils \
    gnupg \
    # --- Build tools (pip packages with native extensions) ---
    build-essential \
    pkg-config \
    # --- Python 3 ---
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    # --- Headless display + optional observation (no desktop environment) ---
    xvfb \
    x11vnc \
    # --- Agent tool dependencies ---
    ssh-client \
    rsync \
    netcat-openbsd \
    procps \
    lsof \
    strace \
    htop \
    && rm -rf /var/lib/apt/lists/*

# ==============================================================================
# SECTION 2: Node.js (NodeSource, major version pinned via ARG)
# ==============================================================================

RUN curl -fsSL "https://deb.nodesource.com/setup_${NODE_MAJOR}.x" | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ==============================================================================
# SECTION 3: Non-root user + writable locations
#   Created BEFORE tool installs so ownership is correct from the start.
#   At runtime, /home/agent must be a tmpfs (read-only rootfs) — see
#   container.rs build_host_config.
# ==============================================================================

RUN groupadd --gid "${SANDBOX_GID}" "${SANDBOX_USER}" \
    && useradd --uid "${SANDBOX_UID}" --gid "${SANDBOX_GID}" \
        --create-home --home-dir "/home/${SANDBOX_USER}" \
        --shell /bin/bash "${SANDBOX_USER}" \
    && mkdir -p /workspace /opt/shiroscout \
    && chown -R "${SANDBOX_UID}:${SANDBOX_GID}" /workspace "/home/${SANDBOX_USER}"

ENV HOME=/home/agent

# ==============================================================================
# SECTION 4: Python venv + Playwright (pinned) + Chromium
#   Browsers go to a world-readable shared path, NOT /root/.cache,
#   so uid 1000 can actually use them.
# ==============================================================================

RUN python3 -m venv /opt/agent-venv \
    && /opt/agent-venv/bin/pip install --no-cache-dir --upgrade pip

ENV PATH="/opt/agent-venv/bin:${PATH}"
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright

RUN npm install -g "playwright@${PLAYWRIGHT_VERSION}" \
    && playwright install --with-deps chromium \
    && chmod -R a+rX "${PLAYWRIGHT_BROWSERS_PATH}" \
    && rm -rf /var/lib/apt/lists/* /root/.npm

# ==============================================================================
# SECTION 5: Entrypoint (keeps container alive; host drives via exec)
# ==============================================================================

COPY entrypoint.sh /opt/shiroscout/entrypoint.sh
RUN chmod 0755 /opt/shiroscout/entrypoint.sh

WORKDIR /workspace
USER ${SANDBOX_UID}:${SANDBOX_GID}

ENTRYPOINT ["/opt/shiroscout/entrypoint.sh"]
