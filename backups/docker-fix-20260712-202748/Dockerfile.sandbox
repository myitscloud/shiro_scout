# ==============================================================================
# ShiroScout Agent Sandbox Docker Image
# ==============================================================================
#
# Purpose:  Isolated runtime for AgentKit AI coding agents. All agent tool
#           execution, code runs, browser automation, and MCP servers live here.
#
# Security: air-gapped (network_mode: none), read-only rootfs, no-new-privileges
#           LLM calls proxied through Tauri host - the sandbox never touches
#           API keys or the internet directly.
#
# Base:     debian:bookworm-slim - chosen for stability, compatibility with
#           Playwright/Chromium, and broad package availability. Not Alpine,
#           because musl compatibility issues with Playwright and agent tooling
#           outweigh the size savings. Size is not the primary concern.
#
# Maintainers: Windows Systems Architect | Security Engineer (blocking)
# ==============================================================================

FROM debian:bookworm-slim AS sandbox

LABEL maintainer="ShiroScout Team"
LABEL description="AgentKit runtime sandbox for ShiroScout AI coding agent manager"
LABEL security.air-gapped="true"

# ==============================================================================
# ARG / ENV
# ==============================================================================

ARG DEBIAN_FRONTEND=noninteractive

# Node.js major version (matches AgentKit requirements)
ARG NODE_MAJOR=22

# Non-root sandbox user
ARG SANDBOX_UID=1000
ARG SANDBOX_GID=1000
ARG SANDBOX_USER=agent

# Bridge binary (copied from local build output or multi-stage)
ARG BRIDGE_BINARY=agent-bridge

# AgentKit version pins
ARG AGENTKIT_VERSION=0.10.4
ARG AGENTKIT_LANGCHAIN_VERSION=0.3.0

# ==============================================================================
# SECTION 1: System Packages (Stable, rarely changes)
# ==============================================================================

RUN apt-get update && apt-get install -y --no-install-recommends \
    # --- Base utilities ---
    ca-certificates \
    curl \
    wget \
    git \
    jq \
    unzip \
    xz-utils \
    gnupg \
    # --- Build tools (for pip packages that compile native extensions) ---
    build-essential \
    pkg-config \
    # --- Python 3 (system-wide) ---
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    # --- X11 / Virtual framebuffer (for headless browser and VNC) ---
    xvfb \
    x11vnc \
    xfce4 \
    xfce4-goodies \
    tightvncserver \
    dbus-x11 \
    dbus-user-session \
    # --- Browser dependencies (Playwright/Chromium) ---
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    # --- Agent tool dependencies ---
    ssh-client \
    rsync \
    netcat-openbsd \
    procps \
    lsof \
    strace \
    htop \
    && rm -rf /var/lib/apt/lists/*

# ==============================================================================
# SECTION 2: Node.js 22 (via NodeSource)
# ==============================================================================

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g --legacy-peer-deps npm@latest \
    && rm -rf /var/lib/apt/lists/*

# ==============================================================================
# SECTION 3: Python Virtual Environment
# ==============================================================================

RUN python3 -m venv /opt/agent-venv \
    && /opt/agent-venv/bin/pip install --no-cache-dir \
        pip --upgrade

ENV PATH="/opt/agent-venv/bin:$PATH"

# ==============================================================================
# SECTION 4: Playwright + Chromium
# ==============================================================================

RUN npx playwright install chromium \
    && npx playwright install-deps chromium

# ==============================================================================
# SECTION 5: Bridge Binary (Rust axum per ADR-003)
# ==============================================================================

ARG BRIDGE_BINARY=agent-bridge

COPY ${BRIDGE_BINARY} /opt/shiroscout/agent-bridge
RUN chmod +x /opt/shiroscout/agent-bridge

# ==============================================================================
# SECTION 6: Entrypoint
# ==============================================================================

COPY entrypoint.sh /opt/shiroscout/entrypoint.sh
RUN chmod +x /opt/shiroscout/entrypoint.sh

EXPOSE 8080
WORKDIR /workspace
ENTRYPOINT ["/opt/shiroscout/entrypoint.sh"]
